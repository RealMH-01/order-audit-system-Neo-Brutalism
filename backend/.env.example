# ===== 应用基础配置 =====
APP_ENV=development
APP_NAME=Order Audit System API
APP_VERSION=0.1.0
API_V1_PREFIX=/api
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ===== Supabase 配置 =====
# 不配置时系统自动使用 RuntimeStore 内存态 fallback，所有功能正常但数据不持久化
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Fernet 加密密钥，用于加密存储用户的 LLM API Key
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 以下为示例值，请替换为自己生成的密钥
ENCRYPTION_KEY=8sNixl3fc4ls8hC_jyLvDqJrRZ6xqU1FffMtymlj2k0=

# ===== LLM API 配置 =====
# 至少配置一组即可使用对应模型提供商

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# DeepSeek（V4 已发布，推荐使用 deepseek-v4-flash / deepseek-v4-pro）
# 旧模型名 deepseek-chat / deepseek-reasoner 将于 2026/07/24 废弃，系统已兼容
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 智谱
ZHIPUAI_API_KEY=

# ===== 默认模型配置 =====
# 当用户 profile 中未指定模型时使用以下默认值
DEFAULT_LLM_PROVIDER=openai
DEFAULT_TEXT_MODEL=gpt-4o
DEFAULT_REASONING_MODEL=o3-mini
DEFAULT_VISION_MODEL=gpt-4o
